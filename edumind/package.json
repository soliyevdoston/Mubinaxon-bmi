{
  "name": "edumind",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "db:push": "pnpm --filter @edumind/database db:push",
    "db:generate": "pnpm --filter @edumind/database db:generate",
    "db:migrate": "pnpm --filter @edumind/database db:migrate",
    "db:seed": "pnpm --filter @edumind/database db:seed",
    "db:studio": "pnpm --filter @edumind/database db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "eslint": "^9.17.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
