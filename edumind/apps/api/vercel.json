{
  "version": 2,
  "buildCommand": "cd ../.. && pnpm --filter @edumind/api build",
  "installCommand": "cd ../.. && pnpm install",
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.ts"
    }
  ]
}
